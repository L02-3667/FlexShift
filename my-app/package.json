{
  "name": "flexshift-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "typecheck:backend": "node ./scripts/run-workspace-script.mjs backend typecheck",
    "prettier:check": "prettier --check .",
    "test": "jest --config jest.config.js --runInBand",
    "test:unit": "jest --config jest.config.js --runInBand src/utils src/services src/context src/hooks",
    "test:components": "jest --config jest.config.js --runInBand src/components src/screens --testPathIgnorePatterns snapshot\\.test\\.tsx$",
    "test:snapshots": "jest --config jest.config.js --runInBand snapshot.test.tsx",
    "test:coverage": "jest --config jest.config.js --runInBand --coverage",
    "test:resilience": "jest --config jest.config.js --runInBand api-client.test.ts sync-engine.test.ts app-context.offline.test.tsx validation.test.ts",
    "test:backend": "node ./scripts/run-workspace-script.mjs backend test",
    "test:backend:integration": "node ./scripts/run-workspace-script.mjs backend test:integration",
    "test:backend:concurrency": "node ./scripts/run-workspace-script.mjs backend test:concurrency",
    "test:backend:coverage": "node ./scripts/run-workspace-script.mjs backend test:coverage",
    "test:e2e:ready": "node ./scripts/run-maestro-check.mjs",
    "test:e2e": "node ./scripts/run-maestro-check.mjs --run",
    "audit:static": "node ./scripts/run-static-audits.mjs",
    "quality:gate": "node ./scripts/run-quality-gate.mjs",
    "quality:gate:ci": "node ./scripts/run-quality-gate.mjs --ci",
    "verify:release": "node ./scripts/run-quality-gate.mjs",
    "verify:release:build": "node ./scripts/run-quality-gate.mjs --build",
    "build:mobile:check": "expo export --platform web --output-dir reports/build/mobile-web",
    "build:backend": "node ./scripts/run-workspace-script.mjs backend build",
    "build:guarded": "node ./scripts/run-quality-gate.mjs --build",
    "backend:dev": "node ./scripts/run-workspace-script.mjs backend start:dev",
    "backend:db:create": "node ./scripts/run-workspace-script.mjs backend db:create",
    "backend:db:check": "node ./scripts/run-workspace-script.mjs backend db:check",
    "backend:prisma:generate": "node ./scripts/run-workspace-script.mjs backend prisma:generate",
    "backend:prisma:format": "node ./scripts/run-workspace-script.mjs backend prisma:format",
    "backend:prisma:migrate": "node ./scripts/run-workspace-script.mjs backend prisma:migrate",
    "backend:prisma:seed": "node ./scripts/run-workspace-script.mjs backend prisma:seed"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.66.8",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.7",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-testing-library": "^7.13.3",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "jest-junit": "^16.0.0",
    "prettier": "^3.5.3",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
