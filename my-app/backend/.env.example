APP_ENV=development
PORT=3000

# Use the real target database for the environment where the backend runs.
# Local development can point to localhost. Render production should point to Neon.
# Leaving backend/.env on localhost means local backend commands will keep using local Postgres.
DATABASE_URL=postgresql://<db-user>:<db-password>@<db-host>:<db-port>/<db-name>?schema=public

JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret

# Native mobile requests usually have no Origin header and are still allowed.
# Browser origins must be listed explicitly here.
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
CORS_ALLOW_CREDENTIALS=false

# Base public service URL only. Do not append /api here.
PUBLIC_API_BASE_URL=http://127.0.0.1:3000
API_DOCS_ENABLED=true
API_DOCS_PATH=docs

SYNC_BATCH_LIMIT=250
SYNC_DEFAULT_STALE_MS=300000

# Optional local database bootstrap only.
POSTGRES_ADMIN_URL=postgresql://postgres:<admin-password>@127.0.0.1:5432/postgres?schema=public
POSTGRES_DB=flexshift
POSTGRES_SHADOW_DB=flexshift_shadow
