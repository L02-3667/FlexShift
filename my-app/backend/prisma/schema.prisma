generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  employee
  manager
  admin
}

enum ShiftStatus {
  scheduled
  completed
  cancelled
}

enum OpenShiftStatus {
  open
  claimed
  cancelled
}

enum RequestType {
  leave
  yield
}

enum RequestStatus {
  pending
  approved
  rejected
}

enum NotificationType {
  request_approved
  request_rejected
  shift_assigned
  open_shift_match
  schedule_updated
  announcement_published
}

enum ChecklistStatus {
  open
  in_progress
  completed
}

model User {
  id                      String            @id @default(cuid())
  fullName                String
  email                   String            @unique
  phone                   String?           @unique
  passwordHash            String
  role                    UserRole
  isActive                Boolean           @default(true)
  settings                UserSetting?
  assignments             ShiftAssignment[]
  requests                Request[]         @relation("CreatedRequests")
  targetRequests          Request[]         @relation("TargetRequests")
  notifications           Notification[]
  sessions                Session[]
  createdLogs             AuditLog[]        @relation("AuditActor")
  targetedAcks            AnnouncementAck[]
  createdAnnouncements    Announcement[]    @relation("AnnouncementAuthor")
  createdChecklists       Checklist[]       @relation("ChecklistCreator")
  assignedChecklists      Checklist[]       @relation("ChecklistAssignee")
  checklistItemsCompleted ChecklistItem[]   @relation("ChecklistItemCompleter")
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
}

model Store {
  id         String      @id @default(cuid())
  name       String
  code       String      @unique
  shifts     Shift[]
  openShifts OpenShift[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  checklists Checklist[]
}

model Position {
  id         String      @id @default(cuid())
  name       String      @unique
  shifts     Shift[]
  openShifts OpenShift[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Shift {
  id          String            @id @default(cuid())
  storeId     String
  positionId  String
  date        DateTime
  startTime   String
  endTime     String
  status      ShiftStatus       @default(scheduled)
  store       Store             @relation(fields: [storeId], references: [id])
  position    Position          @relation(fields: [positionId], references: [id])
  assignments ShiftAssignment[]
  requests    Request[]
  checklists  Checklist[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([storeId, date, status])
  @@index([positionId, date])
  @@index([status, date])
  @@index([updatedAt])
}

model ShiftAssignment {
  id        String   @id @default(cuid())
  shiftId   String
  userId    String
  shift     Shift    @relation(fields: [shiftId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([shiftId, userId])
  @@index([userId, createdAt])
  @@index([shiftId])
}

model OpenShift {
  id          String          @id @default(cuid())
  storeId     String
  positionId  String
  date        DateTime
  startTime   String
  endTime     String
  note        String
  status      OpenShiftStatus @default(open)
  claimedById String?
  store       Store           @relation(fields: [storeId], references: [id])
  position    Position        @relation(fields: [positionId], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([status, date, updatedAt])
  @@index([storeId, date])
  @@index([claimedById, updatedAt])
}

model Request {
  id              String           @id @default(cuid())
  type            RequestType
  status          RequestStatus    @default(pending)
  createdById     String
  targetUserId    String?
  shiftId         String
  reason          String
  managerNote     String?
  createdBy       User             @relation("CreatedRequests", fields: [createdById], references: [id])
  targetUser      User?            @relation("TargetRequests", fields: [targetUserId], references: [id])
  shift           Shift            @relation(fields: [shiftId], references: [id])
  approvalActions ApprovalAction[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status, createdAt])
  @@index([createdById, status])
  @@index([shiftId, status])
  @@index([targetUserId, status])
  @@index([updatedAt])
}

model ApprovalAction {
  id        String        @id @default(cuid())
  requestId String
  managerId String
  action    RequestStatus
  note      String?
  request   Request       @relation(fields: [requestId], references: [id])
  createdAt DateTime      @default(now())

  @@index([requestId, createdAt])
  @@index([managerId, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  body      String
  type      NotificationType
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId, isRead, createdAt])
  @@index([updatedAt])
}

model UserSetting {
  userId                 String   @id
  notificationsEnabled   Boolean  @default(true)
  approvalUpdatesEnabled Boolean  @default(true)
  openShiftAlertsEnabled Boolean  @default(true)
  remindersEnabled       Boolean  @default(true)
  reminderMinutesBefore  Int      @default(60)
  language               String   @default("vi")
  theme                  String   @default("system")
  updatedAt              DateTime @updatedAt
  user                   User     @relation(fields: [userId], references: [id])
}

model Session {
  id                      String     @id @default(cuid())
  userId                  String
  refreshToken            String
  refreshTokenFingerprint String     @unique
  deviceId                String
  deviceName              String
  platform                String
  appVersion              String?
  ipAddress               String?
  userAgent               String?
  expiresAt               DateTime
  lastSeenAt              DateTime   @default(now())
  revokedAt               DateTime?
  revokedReason           String?
  createdAt               DateTime   @default(now())
  user                    User       @relation(fields: [userId], references: [id])
  auditLogs               AuditLog[]

  @@index([userId, expiresAt])
  @@index([userId, deviceId, revokedAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  sessionId   String?
  requestId   String?
  deviceId    String?
  entityType  String
  entityId    String
  action      String
  summary     String
  payload     Json?
  createdAt   DateTime @default(now())
  actorUser   User?    @relation("AuditActor", fields: [actorUserId], references: [id])
  session     Session? @relation(fields: [sessionId], references: [id])

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([requestId])
}

model SyncChange {
  id         Int      @id @default(autoincrement())
  domain     String
  entityType String
  entityId   String
  operation  String
  userId     String?
  changedAt  DateTime @default(now())

  @@index([id, userId])
  @@index([domain, id])
  @@index([entityType, entityId])
}

model MutationRecord {
  clientMutationId String   @id
  userId           String
  mutationType     String
  entityType       String?
  entityId         String?
  dedupeKey        String?
  response         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId, mutationType, dedupeKey])
}

model Announcement {
  id               String            @id @default(cuid())
  title            String
  body             String
  scopeRole        UserRole?
  requiresAck      Boolean           @default(false)
  createdById      String
  publishedAt      DateTime          @default(now())
  expiresAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  createdBy        User              @relation("AnnouncementAuthor", fields: [createdById], references: [id])
  acknowledgements AnnouncementAck[]

  @@index([publishedAt, expiresAt])
  @@index([scopeRole, publishedAt])
}

model AnnouncementAck {
  announcementId String
  userId         String
  acknowledgedAt DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@id([announcementId, userId])
  @@index([userId, acknowledgedAt])
}

model Checklist {
  id          String          @id @default(cuid())
  title       String
  description String?
  status      ChecklistStatus @default(open)
  storeId     String?
  shiftId     String?
  createdById String
  assigneeId  String?
  dueAt       DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  store       Store?          @relation(fields: [storeId], references: [id])
  shift       Shift?          @relation(fields: [shiftId], references: [id])
  createdBy   User            @relation("ChecklistCreator", fields: [createdById], references: [id])
  assignee    User?           @relation("ChecklistAssignee", fields: [assigneeId], references: [id])
  items       ChecklistItem[]

  @@index([status, dueAt])
  @@index([assigneeId, status])
  @@index([storeId, dueAt])
}

model ChecklistItem {
  id            String    @id @default(cuid())
  checklistId   String
  label         String
  sortOrder     Int       @default(0)
  isCompleted   Boolean   @default(false)
  completedAt   DateTime?
  completedById String?
  createdAt     DateTime  @default(now())
  checklist     Checklist @relation(fields: [checklistId], references: [id])
  completedBy   User?     @relation("ChecklistItemCompleter", fields: [completedById], references: [id])

  @@index([checklistId, sortOrder])
  @@index([completedById, completedAt])
}
